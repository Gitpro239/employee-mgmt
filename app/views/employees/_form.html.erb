
<%= form_with(model: employee, data: { turbo: false}) do |form| %>


    <div>
     <%= form.label :first_name %><br>
     <%= form.text_field :first_name %>
     <% if @employee.errors.include?(:first_name) %>
     <% @employee.errors.full_messages_for(:first_name).each do |error_message| %>
      <p style="color: red; font-size: 16px;"> <%= error_message %>.</p>
     <% end %>
     <% end %>
    </div>
 
    <div>
     <%= form.label :last_name %><br>
     <%= form.text_field :last_name %>
    <% if @employee.errors.include?(:last_name) %>
     <% @employee.errors.full_messages_for(:last_name).each do |error_message| %>
      <p style="color: red; font-size: 16px;"> <%= error_message %>.</p>
     <% end %>
     <% end %>
    </div>
 
   <div>
    <%= form.label :email %><br>
    <%= form.email_field :email %>
   <% if @employee.errors.include?(:email) %>
     <% @employee.errors.full_messages_for(:email).each do |error_message| %>
      <p style="color: red; font-size: 16px;"> <%= error_message %>.</p>
     <% end %>
     <% end %>
   </div>

   <div>
      <%= form.label :gender %><br>
      <%= form.select(:gender, [["Male", "male"], ["Female", "female"], ["Other", "other"]], { prompt: 'Choose a gender' }, required: true ) %>
   </div>

  <div>
   <%= form.label :role_id, "Role" %><br>
   <%= form.collection_select(:role_id, @roles, :id, :name, { prompt: 'Choose a role' }, required: true) %>
  </div>
 
  <div>
   <%= form.label :department_id, "Department" %><br>
   <%# <%= form.collection_select(:department_id, @departments, :id, :name, { prompt: 'Choose a department' }, required: true) %> 
   <%= form.collection_select :department_id, Department.order(:name), :id, :name, id: "department", prompt: 'Choose a department', required: true %>
  </div>
 
 <div>
   <%= form.label :phone %><br>
   <%= form.text_field :phone %>
     <% if @employee.errors.include?(:phone) %>
     <% @employee.errors.full_messages_for(:phone).each do |error_message| %>
      <p style="color: red; font-size: 16px;"> <%= error_message %>.</p>
     <% end %>
     <% end %>
 </div>
 
  <div>
  <%= form.label :basic_pay, "Salary" %><br>
  <%= form.text_field :basic_pay %>
    <% if @employee.errors.include?(:basic_pay) %>
     <% @employee.errors.full_messages_for(:basic_pay).each do |error_message| %>
      <p style="color: red; font-size: 16px;"> <%= error_message %>.</p>
     <% end %>
     <% end %>
  </div>
 
    <div>
     <%= form.label :allowances %><br>
     <%= form.text_field :allowances %>
    </div>
 
    <div>
     <%= form.label :hire_date %><br>
     <%= form.date_field :hire_date %>
     <% if @employee.errors.include?(:hire_date) %>
     <% @employee.errors.full_messages_for(:hire_date).each do |error_message| %>
      <p style="color: red; font-size: 16px;"> <%= error_message %>.</p>
     <% end %>
     <% end %>
    </div>
 
   <div>
    <%= form.submit %>
   </div>
    <% end %> 


